# Public client settings from Supabase Project Settings > API Keys.
# Never put OPENAI_API_KEY or a Supabase secret/service-role key in VITE_*.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Cost-safe default. true = real analysis only (when Supabase is configured)
# and the original photo; false = real analysis + image generation.
# Restart Vite after changing it.
VITE_AI_TEST_MODE=true